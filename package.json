{
  "name": "runcor-dialectic",
  "version": "0.1.0",
  "description": "Player/Coach/Judge structured-reasoning dialectic for LLMs. Comparable quality to single-model calls at 25% of the cost.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "CLAUDE.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:regression": "vitest run tests/regression",
    "example:single-call": "tsx examples/single-call.ts",
    "example:15-problems": "tsx examples/15-problems.ts",
    "example:custom-provider": "tsx examples/custom-provider.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "llm",
    "dialectic",
    "reasoning",
    "multi-model",
    "convergence",
    "runcor",
    "structured-reasoning",
    "agent"
  ],
  "author": "Jaz Sunda",
  "license": "MIT",
  "homepage": "https://runcor.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/runcor-ai/runcor-dialectic.git"
  },
  "bugs": {
    "url": "https://github.com/runcor-ai/runcor-dialectic/issues"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
